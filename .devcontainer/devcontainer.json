{
	"name": "Node.js & TypeScript Testing Lab",
	"image": "mcr.microsoft.com/devcontainers/typescript-node:1-20-bullseye",
	"features": {
		"ghcr.io/devcontainers/features/desktop-lite:1": {},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers-contrib/features/k6:1": {}
	},
	"forwardPorts": [
		6080,
		5901,
		5173, // Frontend
		8888  // Backend
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"streetsidesoftware.code-spell-checker",
				"EditorConfig.EditorConfig",
				"dbaeumer.vscode-eslint",
				"vitest.explorer",
				"ms-playwright.playwright" 
			]
		}
	},
	"postCreateCommand": "docker run -d --name mongodb -p 27017:27017 mongo:latest && cd backend && npm install && cd ../frontend && npm install && npx playwright install-deps && npx playwright install chromium"
}